# Exercise 1 — Beacon API: retrieve 5 biosamples for Small cell carcinoma, NOS

import requests
import pandas as pd

# Step 1: define the endpoint and query parameters
url = "https://progenetix.org/beacon/biosamples"

params = {
    "filters": "pgx:icdom-80413",   # Small cell carcinoma, NOS (ICD-O morphology code)
    "limit": 5
}

# Step 2: send the GET request
response = requests.get(url, params=params)
print("HTTP status code:", response.status_code)  # Expected: 200

# Step 3: convert to JSON and inspect top-level structure
data = response.json()
print("Top-level keys:", list(data.keys()))
# Expected: ['meta', 'response', 'responseSummary', ...]

# Step 4: navigate to the result set
result_set = data["response"]["resultSets"][0]
print("Result set keys:", list(result_set.keys()))
# Expected: ['id', 'results', 'resultsCount', ...]

# Step 5: extract the individual records
results = result_set["results"]
print("Number of records returned:", len(results))   # Should be 5 (our limit)
print("Total matching biosamples in DB:", result_set["resultsCount"])

# Step 6: convert to a flat DataFrame
df_ex1 = pd.json_normalize(results)
print("DataFrame shape:", df_ex1.shape)

# Step 7: show the first rows
df_ex1[["id", "individualId", "biosampleStatus.label",
        "histologicalDiagnosis.label", "icdoMorphology.label",
        "icdoTopography.label"]].head()

# Exercise 2 — sampletable download for Small cell carcinoma, NOS

from io import StringIO

# The sampletable service returns a tab-separated flat table.
# limit=0 requests ALL matching samples (not just 5).
sampletable_url = (
    "https://progenetix.org/services/sampletable/"
    "?filters=pgx:icdom-80413&limit=0"
)

response_st = requests.get(sampletable_url, timeout=120)
response_st.raise_for_status()

df_ex2 = pd.read_csv(StringIO(response_st.text), sep="\t")
df_ex2["source_query"] = "small_cell_carcinoma_icdom"

print("sampletable shape:", df_ex2.shape)
df_ex2.head()


# Exercise 3 — Explore diagnostic labels in the sampletable

# 3a. Count histological_diagnosis_label values
print("=== histological_diagnosis_label ===")
print(df_ex2["histological_diagnosis_label"].value_counts(dropna=False).head(15))
print()

# 3b. Count icdo_morphology_label values
print("=== icdo_morphology_label ===")
print(df_ex2["icdo_morphology_label"].value_counts(dropna=False).head(15))
print()

# 3c. Count icdo_topography_label values
print("=== icdo_topography_label ===")
print(df_ex2["icdo_topography_label"].value_counts(dropna=False).head(15))


# Exercise 4 — Download and inspect the CNV frequency table

freq_url = (
    "https://progenetix.org/services/intervalFrequencies/"
    "?output=pgxseg&filters=pgx:icdom-80413"
)

response_freq = requests.get(freq_url, timeout=120)
response_freq.raise_for_status()

# Skip comment lines starting with '#'
df_freq = pd.read_csv(StringIO(response_freq.text), sep="\t", comment="#")

print("Frequency table shape:", df_freq.shape)
print("Columns:", df_freq.columns.tolist())
print()
df_freq.head(10)

# Top bins by gain frequency
df_freq.sort_values("gain_frequency", ascending=False).head(10)

# Top bins by loss frequency
df_freq.sort_values("loss_frequency", ascending=False).head(10)

# Quick plot of gain and loss across the genome
import matplotlib.pyplot as plt

plt.figure(figsize=(14, 4))
plt.plot(df_freq["gain_frequency"].values, color="red", label="Gain", alpha=0.7)
plt.plot(-df_freq["loss_frequency"].values, color="blue", label="Loss", alpha=0.7)
plt.axhline(0, color="black", linewidth=0.5)
plt.xlabel("Genomic bin index")
plt.ylabel("Frequency (%)")
plt.title("CNV frequency profile — Small Cell Carcinoma, NOS")
plt.legend()
plt.tight_layout()
plt.show()

#Interpretation: Small Cell carcinoma shows a unstable CNV profile, which is 
#consistent with its agressive biology. 
# most losses occur in chroosome 3p, 13q and 17p leading to inactivation of RB1 and TP53
#gains in 5p, 8q nd 3q suggest activation of proliferating oncogenes. 

